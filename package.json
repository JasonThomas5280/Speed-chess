{
  "name": "speed-chess",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Mobile-first installable PWA: single-player bullet/blitz chess vs a Stockfish bot. Fully client-side, offline-capable, no backend.",
  "scripts": {
    "predev": "node scripts/copy-stockfish.mjs",
    "dev": "vite",
    "prebuild": "node scripts/copy-stockfish.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit"
  },
  "dependencies": {
    "@lichess-org/chessground": "^10.1.1",
    "chess.js": "^1.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stockfish": "16.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^1.0.0"
  }
}
